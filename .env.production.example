# =============================================
# QR Order Web — Production Environment Variables
# =============================================
# Copy this file to .env and fill in ALL values before deploying.
# Used by docker-compose.yml to configure all services.

# ── Database ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=qr_order

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── JWT Secrets (generate with: openssl rand -base64 48) ──
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars_refresh_secret

# ── CORS Origins (your production frontend URLs, comma-separated) ──
# IMPORTANT: Must match EXACTLY the domains where admin & customer apps are hosted
CORS_ORIGIN=https://admin.infynarc.com,https://order.infynarc.com

# ── Frontend Build URLs (used at build time by Vite) ──
# These get baked into the frontend JS bundles during docker build
VITE_API_URL=https://api.infynarc.com/api
VITE_SOCKET_URL=https://api.infynarc.com
VITE_CUSTOMER_URL=https://order.infynarc.com

# ── SMTP (email verification, notifications) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=QOrder <fynarctechworks@gmail.com>

# ── Twilio (Phone OTP + WhatsApp — leave empty to disable) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=

# ── Twilio WhatsApp Content Template SIDs ──
TWILIO_TPL_LOW_STOCK=
TWILIO_TPL_STAFF_LATE=
TWILIO_TPL_EARLY_CHECKOUT=
TWILIO_TPL_ORDER_INVOICE=

# ── AI Chatbot (leave empty to disable) ──
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Biometric Encryption (generate with: openssl rand -hex 32) ──
BIOMETRIC_ENCRYPTION_KEY=
