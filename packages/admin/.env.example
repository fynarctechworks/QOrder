# =============================================
# Admin Panel Environment Variables
# =============================================
# Copy this file to .env and fill in the values.

# Backend API base URL (no trailing slash)
# Local: http://localhost:3000/api | Production: https://api.infynarc.com/api
VITE_API_URL=http://localhost:3000/api

# WebSocket server URL (no trailing slash)
# Local: http://localhost:3000 | Production: https://api.infynarc.com
VITE_SOCKET_URL=http://localhost:3000

# Customer-facing website URL (used for QR code generation)
# Local: http://localhost:5174 | Production: https://qorderscan.infynarc.com
VITE_CUSTOMER_URL=http://localhost:5174
