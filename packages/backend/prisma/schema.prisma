// Prisma Schema for QR Order System
// Multi-tenant PostgreSQL database with row-level security

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT / RESTAURANT ====================

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  address     String?
  phone       String?
  email       String?
  timezone    String   @default("UTC")
  currency    String   @default("USD")
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  latitude    Float?            // Geo-fence: restaurant latitude
  longitude   Float?            // Geo-fence: restaurant longitude
  geoFenceRadius Int  @default(50) // Geo-fence radius in meters
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users          User[]
  branches       Branch[]
  categories     Category[]
  menuItems      MenuItem[]
  sections       Section[]
  tables         Table[]
  orders         Order[]
  modifierGroups ModifierGroup[]
  tableSessions  TableSession[]
  payments       Payment[]
  suppliers      Supplier[]
  ingredients    Ingredient[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  groupOrders    GroupOrder[]
  discounts      Discount[]
  customers      Customer[]

  @@index([slug])
  @@index([isActive])
}

// ==================== BRANCHES ====================

model Branch {
  id          String   @id @default(uuid())
  name        String
  code        String   // Short code like "MAIN", "DT-01"
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  users          UserBranch[]
  sections       Section[]
  tables         Table[]
  orders         Order[]
  tableSessions  TableSession[]
  payments       Payment[]
  categories     Category[]
  menuItems      MenuItem[]
  modifierGroups ModifierGroup[]
  ingredients    Ingredient[]
  purchaseOrders PurchaseOrder[]

  @@unique([restaurantId, code])
  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([isActive])
}

model UserBranch {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ==================== USERS / AUTH ====================

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

model User {
  id             String    @id @default(uuid())
  email          String?
  username       String    @unique
  passwordHash   String
  name           String
  role           UserRole  @default(STAFF)
  roleTitle      String?
  isActive       Boolean   @default(true)
  isVerified     Boolean   @default(false)
  verificationCode String?
  verificationExpiry DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  refreshTokens RefreshToken[]
  branches      UserBranch[]

  @@index([restaurantId])
  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique // SHA-256 hash of the JWT refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ==================== MENU ====================

model Category {
  id           String   @id @default(uuid())
  name         String
  description  String?
  image        String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  translations Json?    // {"hi":{"name":"...","description":"..."},"ta":{...},...}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Relations
  menuItems MenuItem[]

  @@unique([restaurantId, branchId, name])
  @@index([restaurantId])
  @@index([branchId])
  @@index([sortOrder])
}

enum DietType {
  VEG
  NON_VEG
  EGG
}

model MenuItem {
  id            String    @id @default(uuid())
  name          String
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  discountPrice Decimal?  @db.Decimal(10, 2)
  image         String?
  badge         String?
  dietType      DietType?
  isAvailable   Boolean   @default(true)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  prepTime      Int?      // minutes
  calories      Int?
  tags          String[] @default([])
  ingredients   String[] @default([])
  allergens     String[] @default([])
  translations  Json?    // {"hi":{"name":"...","description":"...","badge":"..."},"ta":{...},...}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Category relation
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relations
  modifierGroups MenuItemModifierGroup[]
  orderItems     OrderItem[]
  recipes        Recipe[]
  groupCartItems GroupCartItem[]

  @@unique([restaurantId, branchId, name, categoryId])
  @@index([restaurantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([isAvailable, isActive])
}

model ModifierGroup {
  id           String   @id @default(uuid())
  name         String   // e.g., "Size", "Toppings"
  description  String?
  minSelect    Int      @default(0)
  maxSelect    Int      @default(1)
  isRequired   Boolean  @default(false)
  translations Json?    // {"hi":{"name":"..."},"ta":{...},...}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Relations
  modifiers  Modifier[]
  menuItems  MenuItemModifierGroup[]

  @@unique([restaurantId, branchId, name])
  @@index([restaurantId])
  @@index([branchId])
}

model Modifier {
  id           String  @id @default(uuid())
  name         String
  price        Decimal @default(0) @db.Decimal(10, 2)
  isDefault    Boolean @default(false)
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)
  translations Json?   // {"hi":{"name":"..."},"ta":{...},...}

  // Modifier group relation
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  // Relations
  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
}

model MenuItemModifierGroup {
  id        String @id @default(uuid())
  sortOrder Int    @default(0)

  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierGroupId])
  @@index([menuItemId])
  @@index([modifierGroupId])
}

// ==================== TABLES ====================

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  INACTIVE
}

model Table {
  id           String      @id @default(uuid())
  number       String
  name         String?     // e.g., "Window Seat 1"
  capacity     Int         @default(4)
  status       TableStatus @default(AVAILABLE)
  qrCode       String?     @unique
  sessionToken String?     @unique @default(uuid()) // Rotates on table clear to prevent remote QR abuse
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation (optional — null means shared across all branches)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Section relation (optional)
  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  // Relations
  orders          Order[]
  tableSessions   TableSession[]
  groupOrders     GroupOrder[]
  serviceRequests ServiceRequest[]

  @@unique([restaurantId, branchId, sectionId, number])
  @@index([restaurantId])
  @@index([branchId])
  @@index([sectionId])
  @@index([status])
  @@index([qrCode])
}

// ==================== SECTIONS / ZONES ====================

model Section {
  id         String   @id @default(uuid())
  name       String   // e.g., "Ground Floor", "Rooftop", "Patio"
  floor      Int?     // Optional floor number
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation (optional — null means shared across all branches)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Relations
  tables Table[]

  @@unique([restaurantId, branchId, name])
  @@index([restaurantId])
  @@index([branchId])
  @@index([sortOrder])
}

// ==================== TABLE SESSIONS ====================

enum SessionStatus {
  ACTIVE
  CLOSED
  MERGED
  TRANSFERRED
}

model TableSession {
  id             String        @id @default(cuid())
  status         SessionStatus @default(ACTIVE)
  startedAt      DateTime      @default(now())
  closedAt       DateTime?
  expiresAt      DateTime?     // Auto-expire the session after this time
  lastActivityAt DateTime      @default(now()) // Bumped on each order placement
  totalAmount    Decimal       @default(0) @db.Decimal(10, 2)
  subtotal       Decimal       @default(0) @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  invoiceId      String?
  mergedIntoId   String?       // Reference to target session if merged
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation (optional)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Customer phone verification
  customerPhone String?
  phoneVerified Boolean @default(false)

  // Table relation
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Relations
  orders   Order[]
  payments Payment[]

  @@index([restaurantId])
  @@index([branchId])
  @@index([tableId])
  @@index([status])
  @@index([startedAt])
}

// ==================== PAYMENTS ====================

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  ONLINE // Gateway payment (Razorpay, Stripe, etc.)
  CREDIT // Charged to a credit account (pay later)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(COMPLETED)
  reference String?       // Transaction reference / receipt number
  notes     String?

  // Payment gateway fields
  gatewayProvider  String?  // 'razorpay', 'stripe', etc.
  gatewayOrderId   String?  // e.g. Razorpay order_xxx
  gatewayPaymentId String?  // e.g. Razorpay pay_xxx
  gatewaySignature String?  // Verification signature
  gatewayData      Json?    // Full gateway response for audit
  refundId         String?  // Gateway refund ID
  refundAmount     Decimal? @db.Decimal(10, 2)
  refundedAt       DateTime?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Session relation
  sessionId String
  session   TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation (optional)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([restaurantId])
  @@index([branchId])
  @@index([createdAt])
  @@unique([gatewayPaymentId], map: "Payment_gatewayPaymentId_unique")
}

// ==================== ORDERS ====================

enum OrderStatus {
  PENDING
  PREPARING
  READY
  PAYMENT_PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id            String           @id @default(uuid())
  orderNumber   String           // Human-readable order number
  status        OrderStatus      @default(PENDING)
  subtotal      Decimal          @db.Decimal(10, 2)
  discount      Decimal          @default(0) @db.Decimal(10, 2) // Total discount applied
  tax           Decimal          @db.Decimal(10, 2)
  total         Decimal          @db.Decimal(10, 2)
  notes         String?
  customerName  String?
  customerPhone String?
  estimatedTime Int?             // minutes
  preparedAt    DateTime?
  completedAt   DateTime?
  gatewayOrderId String?          // Payment gateway order ID for online payments
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Branch relation (optional)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Table relation (optional for pickup orders)
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Session relation (for dine-in orders)
  sessionId String?
  session   TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Relations
  items          OrderItem[]
  groupOrder     GroupOrder?
  orderDiscounts OrderDiscount[]
  feedback       Feedback?
  receipts       Receipt[]

  @@unique([restaurantId, branchId, orderNumber])
  @@index([restaurantId])
  @@index([branchId])
  @@index([tableId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
  @@index([restaurantId, status, createdAt])
}

model OrderItem {
  id           String    @id @default(uuid())
  quantity     Int       @default(1)
  unitPrice    Decimal   @db.Decimal(10, 2)
  totalPrice   Decimal   @db.Decimal(10, 2)
  notes        String?
  preparedAt   DateTime? // Set when chef marks this item as kitchen-ready
  itemSnapshot Json      // Snapshot of menu item at time of order

  // Order relation
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Menu item relation (nullable — menu item may be deleted after order)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  // Relations
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([menuItemId])
}

model OrderItemModifier {
  id    String  @id @default(uuid())
  name  String
  price Decimal @db.Decimal(10, 2)

  // Order item relation
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // Modifier relation
  modifierId String
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([modifierId])
}

// ==================== GROUP ORDERS ====================

enum GroupOrderStatus {
  OPEN        // Accepting participants & cart additions
  LOCKED      // Host locked — no more changes, about to submit
  SUBMITTED   // Host submitted the combined order
  EXPIRED     // Auto-expired after TTL or session reset
  CANCELLED   // Host cancelled
}

model GroupOrder {
  id           String           @id @default(uuid())
  code         String           @unique // 6-char alphanumeric join code
  status       GroupOrderStatus @default(OPEN)
  hostName     String
  hostPhone    String?
  expiresAt    DateTime         // Auto-expire after 2 hours
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Restaurant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Optional table (dine-in) — null for takeaway/delivery groups
  tableId      String?
  table        Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Snapshot of session token at creation time (validated on submit)
  sessionToken String?

  // Link to the final placed order (set on submit)
  orderId      String?  @unique
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Relations
  participants GroupParticipant[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([expiresAt])
}

model GroupParticipant {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  isHost    Boolean  @default(false)
  isReady   Boolean  @default(false)
  joinedAt  DateTime @default(now())

  // Group order relation
  groupOrderId String
  groupOrder   GroupOrder @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)

  // Relations
  cartItems GroupCartItem[]

  @@unique([groupOrderId, name]) // No duplicate names within a group
  @@index([groupOrderId])
}

model GroupCartItem {
  id         String  @id @default(uuid())
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  notes      String?
  modifiers  Json    @default("[]") // Array of { modifierId, name, price }
  createdAt  DateTime @default(now())

  // Menu item relation
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  // Participant relation
  participantId String
  participant   GroupParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([menuItemId])
}

// ==================== DISCOUNTS & COUPONS ====================

enum DiscountType {
  PERCENTAGE
  FLAT
}

model Discount {
  id            String       @id @default(uuid())
  name          String       // "Happy Hour 20% Off", "First Order Discount"
  type          DiscountType
  value         Decimal      @db.Decimal(10, 2) // Percentage (e.g. 20) or flat amount (e.g. 100)
  minOrderAmount Decimal?    @db.Decimal(10, 2) // Minimum cart value to apply
  maxDiscount   Decimal?     @db.Decimal(10, 2) // Cap for percentage discounts
  isAutoApply   Boolean      @default(false) // Auto-apply when conditions met (no code needed)
  activeFrom    DateTime?    // Schedule start (null = always)
  activeTo      DateTime?    // Schedule end (null = always)
  activeDays    Int[]        @default([]) // Days of week 0=Sun..6=Sat (empty = all days)
  activeTimeFrom String?     // "14:00" — happy hour start (null = all day)
  activeTimeTo  String?      // "17:00" — happy hour end
  maxUses       Int?         // Total redemptions allowed (null = unlimited)
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Multi-tenant
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  coupons       Coupon[]
  orderDiscounts OrderDiscount[]

  @@index([restaurantId])
  @@index([isActive, isAutoApply])
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   // "WELCOME10", "FLAT50"
  maxUses     Int?     // Total uses across all customers (null = unlimited)
  usedCount   Int      @default(0)
  maxUsesPerCustomer Int @default(1)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Links to a discount rule
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  // Multi-tenant
  restaurantId String

  // Relations
  orderDiscounts OrderDiscount[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([code])
  @@index([isActive])
}

model OrderDiscount {
  id             String  @id @default(uuid())
  discountAmount Decimal @db.Decimal(10, 2) // Actual amount deducted
  createdAt      DateTime @default(now())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  couponId   String?
  coupon     Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)

  // Track per-customer coupon usage
  customerPhone String?

  @@index([orderId])
  @@index([discountId])
  @@index([couponId])
  @@index([customerPhone])
}

// ==================== SERVICE REQUESTS (WAITER CALLING) ====================

enum ServiceRequestType {
  CALL_WAITER
  WATER
  BILL
  CUSTOM
}

enum ServiceRequestStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

model ServiceRequest {
  id        String               @id @default(uuid())
  type      ServiceRequestType
  status    ServiceRequestStatus @default(PENDING)
  message   String?              // Custom request message
  createdAt DateTime             @default(now())
  resolvedAt DateTime?

  // Table relation
  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  // Multi-tenant
  restaurantId String

  @@index([restaurantId, status])
  @@index([tableId])
  @@index([createdAt])
}

// ==================== CUSTOMER FEEDBACK ====================

model Feedback {
  id             String   @id @default(uuid())
  overallRating  Int      // 1-5
  foodRating     Int?     // 1-5
  serviceRating  Int?     // 1-5
  ambienceRating Int?     // 1-5
  comment        String?
  customerPhone  String?
  createdAt      DateTime @default(now())

  // Order relation
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Session relation
  sessionId String?

  // Multi-tenant
  restaurantId String

  @@index([restaurantId])
  @@index([createdAt])
  @@index([overallRating])
}

// ==================== RECEIPTS ====================

enum ReceiptType {
  EMAIL
  WHATSAPP
  SMS
}

enum ReceiptStatus {
  PENDING
  SENT
  FAILED
}

model Receipt {
  id        String        @id @default(uuid())
  type      ReceiptType
  status    ReceiptStatus @default(PENDING)
  recipient String        // Email or phone number
  sentAt    DateTime?
  error     String?
  createdAt DateTime      @default(now())

  // Order relation
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ==================== INVENTORY ====================

enum UnitType {
  KG
  G
  L
  ML
  PCS
  DOZEN
  BOX
  PACKET
  BUNCH
  PLATE
  CUP
  TBSP
  TSP
}

enum StockMovementType {
  PURCHASE
  USAGE
  ORDER_DEDUCT
  MANUAL_ADD
  MANUAL_DEDUCT
  WASTE
  RETURN
  TRANSFER
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  ingredients IngredientSupplier[]
  purchases   PurchaseOrder[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([isActive])
}

model Ingredient {
  id            String   @id @default(uuid())
  name          String
  unit          UnitType @default(KG)
  currentStock  Decimal  @default(0) @db.Decimal(12, 3)
  minStock      Decimal  @default(0) @db.Decimal(12, 3)
  costPerUnit   Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  recipes        Recipe[]
  suppliers      IngredientSupplier[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseOrderItem[]

  @@unique([restaurantId, branchId, name])
  @@index([restaurantId])
  @@index([branchId])
  @@index([isActive])
}

model Recipe {
  id       String  @id @default(uuid())
  quantity Decimal @db.Decimal(12, 3)

  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
}

model IngredientSupplier {
  id          String  @id @default(uuid())
  costPerUnit Decimal @default(0) @db.Decimal(10, 2)
  isPreferred Boolean @default(false)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, supplierId])
  @@index([ingredientId])
  @@index([supplierId])
}

model StockMovement {
  id           String            @id @default(uuid())
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 3)
  previousQty  Decimal           @db.Decimal(12, 3)
  newQty       Decimal           @db.Decimal(12, 3)
  costPerUnit  Decimal?          @db.Decimal(10, 2)
  reference    String?
  notes        String?
  performedBy  String?
  createdAt    DateTime          @default(now())

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([restaurantId])
  @@index([type])
  @@index([createdAt])
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(10, 2)
  notes       String?
  orderedAt   DateTime?
  receivedAt  DateTime?
  createdBy   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items PurchaseOrderItem[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id          String  @id @default(uuid())
  quantity    Decimal @db.Decimal(12, 3)
  costPerUnit Decimal @db.Decimal(10, 2)
  totalCost   Decimal @db.Decimal(10, 2)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([ingredientId])
}

// ==================== CRM & CUSTOMER INTELLIGENCE ====================

model Customer {
  id            String       @id @default(uuid())
  phone         String
  name          String?
  email         String?
  tags          String[]     @default([])
  notes         String?
  totalVisits   Int          @default(0)
  totalSpend    Decimal      @default(0) @db.Decimal(12, 2)
  avgOrderValue Decimal      @default(0) @db.Decimal(10, 2)
  lastVisitAt   DateTime?
  firstVisitAt  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Multi-tenant
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  interactions CustomerInteraction[]

  @@unique([restaurantId, phone])
  @@index([restaurantId])
  @@index([phone])
  @@index([tags])
  @@index([totalSpend])
  @@index([lastVisitAt])
}

enum InteractionType {
  ORDER
  FEEDBACK
  SERVICE_REQUEST
  PAYMENT
  NOTE
}

model CustomerInteraction {
  id          String          @id @default(uuid())
  type        InteractionType
  summary     String?         // Short description ("Ordered 3 items, total ₹450")
  amount      Decimal?        @db.Decimal(10, 2)
  referenceId String?         // orderId, feedbackId, etc.
  metadata    Json?           // Extra context
  createdAt   DateTime        @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@index([createdAt])
}

// ==================== STAFF MANAGEMENT & PAYROLL ====================

enum ShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  SPLIT
  CUSTOM
}

model StaffShift {
  id          String    @id @default(uuid())
  name        String    // "Morning Shift", "Evening Shift"
  shiftType   ShiftType @default(CUSTOM)
  startTime   String    // "09:00" (24h format)
  endTime     String    // "17:00"
  breakMinutes Int      @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Multi-tenant
  restaurantId String

  // Relations
  assignments ShiftAssignment[]
  attendances Attendance[]

  @@index([restaurantId])
}

model ShiftAssignment {
  id        String   @id @default(uuid())
  date      DateTime @db.Date // The day this assignment is for
  createdAt DateTime @default(now())

  userId  String
  shiftId String
  shift   StaffShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  // Multi-tenant
  restaurantId String

  @@unique([userId, shiftId, date])
  @@index([restaurantId])
  @@index([userId])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

model Attendance {
  id          String           @id @default(uuid())
  date        DateTime         @db.Date
  status      AttendanceStatus @default(PRESENT)
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Decimal?         @db.Decimal(5, 2)
  overtime    Decimal?         @db.Decimal(5, 2)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userId  String
  shiftId String?
  shift   StaffShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  // Multi-tenant
  restaurantId String

  @@unique([userId, date])
  @@index([restaurantId])
  @@index([userId])
  @@index([date])
  @@index([status])
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  COMPENSATORY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String      @id @default(uuid())
  leaveType   LeaveType
  status      LeaveStatus @default(PENDING)
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  reason      String?
  approvedBy  String?     // userId of approver
  respondedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId String

  // Multi-tenant
  restaurantId String

  @@index([restaurantId])
  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model PayrollConfig {
  id              String   @id @default(uuid())
  baseSalary      Decimal  @default(0) @db.Decimal(10, 2)
  overtimeRate    Decimal  @default(1.5) @db.Decimal(5, 2) // Multiplier
  deductions      Json     @default("{}") // { pf: 12, esi: 1.75, tax: 0 }
  allowances      Json     @default("{}") // { hra: 5000, travel: 2000 }
  payDay          Int      @default(1) // Day of month salary is paid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String @unique

  // Multi-tenant
  restaurantId String

  @@index([restaurantId])
}

model PayrollRun {
  id             String   @id @default(uuid())
  month          Int      // 1-12
  year           Int
  baseSalary     Decimal  @db.Decimal(10, 2)
  overtime       Decimal  @default(0) @db.Decimal(10, 2)
  allowances     Decimal  @default(0) @db.Decimal(10, 2)
  deductions     Decimal  @default(0) @db.Decimal(10, 2)
  netPay         Decimal  @db.Decimal(10, 2)
  daysPresent    Int      @default(0)
  daysAbsent     Int      @default(0)
  workingDays    Int      @default(0)
  isPaid         Boolean  @default(false)
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String

  // Multi-tenant
  restaurantId String

  @@unique([userId, month, year])
  @@index([restaurantId])
  @@index([userId])
  @@index([month, year])
  @@index([isPaid])
}

// ==================== CREDIT (UDHAR / TAB) ====================

model CreditAccount {
  id           String   @id @default(uuid())
  name         String   // e.g. "Ajay (Family)"
  phone        String?
  email        String?
  creditLimit  Decimal? @db.Decimal(10, 2) // null = unlimited
  balance      Decimal  @default(0) @db.Decimal(10, 2) // outstanding amount owed
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurantId String
  customerId   String?  // optional link to CRM Customer

  transactions CreditTransaction[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([phone])
  @@index([isActive])
}

model CreditTransaction {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(10, 2) // positive = charge, negative = repayment
  type      String   // 'CHARGE' | 'REPAYMENT'
  method    String?  // payment method used for repayment (CASH, UPI, etc.)
  orderId   String?  // linked order (for charges)
  sessionId String?  // linked session (for charges)
  reference String?  // transaction reference
  notes     String?
  createdBy String?  // user who recorded this
  createdAt DateTime @default(now())

  accountId    String
  account      CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  restaurantId String

  @@index([accountId])
  @@index([restaurantId])
  @@index([type])
  @@index([createdAt])
}
