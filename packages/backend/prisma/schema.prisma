// Prisma Schema for QR Order System
// Multi-tenant PostgreSQL database with row-level security

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT / RESTAURANT ====================

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  coverImage  String?
  address     String?
  phone       String?
  email       String?
  timezone    String   @default("UTC")
  currency    String   @default("USD")
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users          User[]
  categories     Category[]
  menuItems      MenuItem[]
  tables         Table[]
  orders         Order[]
  modifierGroups ModifierGroup[]
  tableSessions  TableSession[]
  payments       Payment[]

  @@index([slug])
  @@index([isActive])
}

// ==================== USERS / AUTH ====================

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String
  name           String
  role           UserRole  @default(STAFF)
  isActive       Boolean   @default(true)
  isVerified     Boolean   @default(false)
  verificationCode String?
  verificationExpiry DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  refreshTokens RefreshToken[]

  @@unique([email, restaurantId])
  @@index([restaurantId])
  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique // SHA-256 hash of the JWT refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ==================== MENU ====================

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  menuItems MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([sortOrder])
}

enum DietType {
  VEG
  NON_VEG
  EGG
}

model MenuItem {
  id            String    @id @default(uuid())
  name          String
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  discountPrice Decimal?  @db.Decimal(10, 2)
  image         String?
  badge         String?
  dietType      DietType?
  isAvailable   Boolean   @default(true)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  prepTime      Int?      // minutes
  calories      Int?
  tags          String[] @default([])
  ingredients   String[] @default([])
  allergens     String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Category relation
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relations
  modifierGroups MenuItemModifierGroup[]
  orderItems     OrderItem[]

  @@unique([restaurantId, name, categoryId])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable, isActive])
}

model ModifierGroup {
  id          String   @id @default(uuid())
  name        String   // e.g., "Size", "Toppings"
  description String?
  minSelect   Int      @default(0)
  maxSelect   Int      @default(1)
  isRequired  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  modifiers  Modifier[]
  menuItems  MenuItemModifierGroup[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model Modifier {
  id        String  @id @default(uuid())
  name      String
  price     Decimal @default(0) @db.Decimal(10, 2)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  // Modifier group relation
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  // Relations
  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
}

model MenuItemModifierGroup {
  id        String @id @default(uuid())
  sortOrder Int    @default(0)

  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, modifierGroupId])
  @@index([menuItemId])
  @@index([modifierGroupId])
}

// ==================== TABLES ====================

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  INACTIVE
}

model Table {
  id        String      @id @default(uuid())
  number    String
  name      String?     // e.g., "Window Seat 1"
  capacity  Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  qrCode    String?     @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Relations
  orders        Order[]
  tableSessions TableSession[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([status])
  @@index([qrCode])
}

// ==================== TABLE SESSIONS ====================

enum SessionStatus {
  ACTIVE
  CLOSED
  MERGED
  TRANSFERRED
}

model TableSession {
  id           String        @id @default(cuid())
  status       SessionStatus @default(ACTIVE)
  startedAt    DateTime      @default(now())
  closedAt     DateTime?
  totalAmount  Decimal       @default(0) @db.Decimal(10, 2)
  subtotal     Decimal       @default(0) @db.Decimal(10, 2)
  tax          Decimal       @default(0) @db.Decimal(10, 2)
  invoiceId    String?
  mergedIntoId String?       // Reference to target session if merged
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Table relation
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Relations
  orders   Order[]
  payments Payment[]

  @@index([restaurantId])
  @@index([tableId])
  @@index([status])
  @@index([startedAt])
}

// ==================== PAYMENTS ====================

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(COMPLETED)
  reference String?       // Transaction reference / receipt number
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Session relation
  sessionId String
  session   TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([restaurantId])
  @@index([createdAt])
}

// ==================== ORDERS ====================

enum OrderStatus {
  PENDING
  PREPARING
  PAYMENT_PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id            String           @id @default(uuid())
  orderNumber   String           // Human-readable order number
  status        OrderStatus      @default(PENDING)
  subtotal      Decimal          @db.Decimal(10, 2)
  tax           Decimal          @db.Decimal(10, 2)
  total         Decimal          @db.Decimal(10, 2)
  notes         String?
  customerName  String?
  customerPhone String?
  estimatedTime Int?             // minutes
  preparedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Multi-tenant relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Table relation (optional for pickup orders)
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Session relation (for dine-in orders)
  sessionId String?
  session   TableSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Relations
  items OrderItem[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([tableId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
  @@index([restaurantId, status, createdAt])
}

model OrderItem {
  id           String  @id @default(uuid())
  quantity     Int     @default(1)
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)
  notes        String?
  itemSnapshot Json    // Snapshot of menu item at time of order

  // Order relation
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Menu item relation
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  // Relations
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([menuItemId])
}

model OrderItemModifier {
  id    String  @id @default(uuid())
  name  String
  price Decimal @db.Decimal(10, 2)

  // Order item relation
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // Modifier relation
  modifierId String
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([modifierId])
}
