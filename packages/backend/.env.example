# =============================================
# Backend Environment Variables
# =============================================
# Copy this file to .env and fill in the values.

# Node environment: development | production | test
NODE_ENV=development

# Port the backend server listens on
PORT=3000

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/qr_order?schema=public"

# Redis connection URL
REDIS_URL="redis://localhost:6379"

# JWT secrets — MUST be at least 32 characters each
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="your-access-secret-key-min-32-chars-long"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-long"

# JWT token expiration durations
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS allowed origins (comma-separated)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# WhatsApp Cloud API (Meta Business)
# Get these from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_TOKEN="your-whatsapp-cloud-api-permanent-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
