# =============================================
# QR Order Web — Root Environment Variables
# =============================================
# Copy this file to .env and fill in the values.

# JWT secrets used by docker-compose.yml for the backend service.
# Must be at least 32 characters each. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# CORS origins allowed by the backend (comma-separated)
# Local: http://localhost:5173,http://localhost:5174
# Production: https://qorderadmin.infynarc.com,https://qorderscan.infynarc.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
